generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Optional advanced connections (enable only if env vars are defined)
  // shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  // directUrl        = env("DATABASE_DIRECT_URL")
}

model User {
  id                        String               @id @default(cuid())
  email                     String               @unique
  emailVerified             DateTime?
  password                  String
  firstName                 String?
  lastName                  String?
  salonName                 String?
  image                     String?
  profileImage              String?
  phone                     String?
  address                   String?
  city                      String?
  postalCode                String?
  instagram                 String?
  website                   String?
  facebook                  String?
  tiktok                    String?
  description               String?
  salonHours                String?
  salonPhotos               String[]
  isInspirationSalon        Boolean              @default(true)

  saasPlan                  SaasPlan             @default(FREE)
  saasPlanUntil             DateTime?

  role                      Role                 @default(user)

  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  prestations               String[]
  style                     String[]

  verifiedSalon            Boolean               @default(false)
  SalonVerificationDocument SalonVerificationDocument[]

  // Contrôle des confirmations de RDV : true = confirmation manuelle, false = confirmation auto
  addConfirmationEnabled    Boolean              @default(false)
  
  // DEPRECATED: Ancien champ pour contrôle agenda (conservé pour compatibilité)
  // À remplacer par salonCanCreateAppointments pour les tatoueurs liés
  appointmentBookingEnabled Boolean              @default(false)
  
  // Permissions pour user_tatoueur lié à un salon
  // Autorise le user_salon à voir l'agenda et les RDV du user_tatoueur
  salonCanViewAppointments  Boolean              @default(true)
  
  // Permissions pour user_tatoueur lié à un salon
  // Autorise le user_salon à créer des RDV pour ce user_tatoueur
  // À UTILISER dans la logique de création de RDV par salon pour tatoueur lié
  salonCanCreateAppointments Boolean             @default(true)

  colorProfile              String?              @default("default")
  colorProfileBis           String?              @default("default")

  stripeCustomerId          String?              
  stripeSubscriptionId      String?              

  // Lien tatoueur ↔ salon (uniquement pour role user_tatoueur)
  salonId                   String?
  salon                     User?                @relation("SalonTatoueurs", fields: [salonId], references: [id])
  linkedTatoueurs           User[]               @relation("SalonTatoueurs")

  appointments              Appointment[]
  appointmentsAsPerformer    Appointment[]        @relation("AppointmentPerformer")
  appointmentConsumables    AppointmentConsumable[]
  blockedTimeSlots          BlockedTimeSlot[]

  Client                    Client[]
  FollowUpRequest           FollowUpRequest[]
  FollowUpSubmission        FollowUpSubmission[]

  Portfolio                 Portfolio[]
  Flash                     Flash[]
  ProductSalon              ProductSalon[]

  saasPlanDetails           SaasPlanDetails?
  
  Tatoueur                  Tatoueur[]
  TimeSlot                  TimeSlot[]

  StockItem                  StockItem[]
  PiercingPrice             PiercingPrice[]
  PiercingServicePrice      PiercingServicePrice[]

  // Nouvelles propriétés pour les clients
  clientProfile         ClientProfile?
  favoriteUsers         FavoriteUser[]       @relation("ClientFavorites")
  favoritedBy           FavoriteUser[]       @relation("FavoritedSalon")
  favoritePortfolios    FavoritePortfolio[]  @relation("ClientFavoritePortfolios")
  reviewsGiven          SalonReview[]        @relation("ReviewAuthor")
  reviewsReceived       SalonReview[]        @relation("ReviewedSalon")

  // Nouvelle relation pour les RDV pris en tant que client connecté
  appointmentsAsClient      Appointment[]        @relation("ClientUserAppointments")

  linkedClientProfiles      Client[]             @relation("LinkedClientProfile")

  // Propriétés pour la messagerie
  conversationsAsSalon      Conversation[]        @relation("SalonConversations")
  conversationsAsClient     Conversation[]        @relation("ClientUserConversations")
  messagesSent              Message[]
  messageNotifications      MessageNotification[]
  notificationPreference    NotificationPreference?

  // Statistiques visites profil public
  salonProfileViews         SalonProfileView[]    @relation("SalonProfileViews")

  // Demandes d'invitation d'équipe (salon -> tatoueur user)
  sentTeamRequests          SalonTatoueurTeamRequest[] @relation("TeamRequestsSentBySalon")
  receivedTeamRequests      SalonTatoueurTeamRequest[] @relation("TeamRequestsReceivedByTatoueur")
}

//! MODEL POUR STOCKER LES INFOS D'UN CLIENT CONNECTÉ
model ClientProfile {
  id          String      @id @default(cuid())
  userId      String      @unique
  pseudo      String?
  birthDate   DateTime?
  city        String?
  postalCode  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  moodboards  Moodboard[]
}

//! MODEL POUR LES MOODBOARDS (inspirations tattoo du client)
model Moodboard {
  id              String           @id @default(cuid())
  clientProfileId String
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  clientProfile   ClientProfile    @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  images          MoodboardImage[]
  appointments    Appointment[]

  @@index([clientProfileId])
}

//! MODEL POUR LES IMAGES D'UN MOODBOARD
model MoodboardImage {
  id          String    @id @default(cuid())
  moodboardId String
  url         String
  caption     String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())

  moodboard   Moodboard @relation(fields: [moodboardId], references: [id], onDelete: Cascade)

  @@index([moodboardId])
}

//! MODEL POUR LES FAVORIS (clients qui ajoutent des salons en favoris)
model FavoriteUser {
  id          String   @id @default(cuid())
  clientId    String
  salonId     String
  createdAt   DateTime @default(now())

  client      User     @relation("ClientFavorites", fields: [clientId], references: [id], onDelete: Cascade)
  salon       User     @relation("FavoritedSalon", fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([clientId, salonId])
}

//! MODEL POUR LES AVIS SUR LES SALONS (clients connectés qui évaluent des salons)
model SalonReview {
  id                    String        @id @default(cuid())
  authorId              String        // Client qui laisse l'avis (role = "client")
  salonId               String        // Salon évalué (role = "user")
  appointmentId         String?       @unique // RDV associé (optionnel mais recommandé pour vérification)
  rating                Int           // Note de 1 à 5
  title                 String?       // Titre de l'avis
  comment               String?       // Commentaire
  photos                String[]      // URLs des photos (optionnel)
  isVerified            Boolean       @default(false) // Avis vérifié (basé sur un RDV réel)
  isVisible             Boolean       @default(true)  // Visible publiquement
  salonResponse         String?       // Réponse du salon
  salonRespondedAt      DateTime?     // Date de réponse du salon
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  author                User          @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  salon                 User          @relation("ReviewedSalon", fields: [salonId], references: [id], onDelete: Cascade)
  appointment           Appointment?  @relation(fields: [appointmentId], references: [id])
  
  @@index([salonId])
  @@index([authorId])
  @@index([rating])
  @@index([createdAt])
  @@index([isVisible])
}

//! MODEL POUR TRACKER LES VISITES DU PROFIL PUBLIC SALON
model SalonProfileView {
  id                String    @id @default(cuid())
  salonId           String    // ID du salon (User)
  viewerIpHash      String?   // Hash de l'IP du visiteur (pour anonymiser)
  referrer          String?   // Source du trafic (google, direct, etc.)
  userAgent         String?   // User-Agent du navigateur
  country           String?   // Pays détecté (optionnel)
  city              String?   // Ville détectée (optionnel)
  deviceType        String?   // DESKTOP, MOBILE, TABLET
  createdAt         DateTime  @default(now())
  
  salon             User      @relation("SalonProfileViews", fields: [salonId], references: [id], onDelete: Cascade)
  
  @@index([salonId, createdAt])
  @@index([createdAt])
  @@index([deviceType])
}

//! MODEL POUR LES TATOUEURS DANS LE SALON
model Tatoueur {
  id                 String              @id @default(cuid())
  name               String
  hours              String?
  userId             String
  img                String?
  description        String?
  phone              String?
  instagram          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  skills             String[]
  style              String[]
  rdvBookingEnabled  Boolean             @default(true)
  appointments       Appointment[]
  blockedTimeSlots   BlockedTimeSlot[]
  Portfolio          Portfolio[]
  Flash              Flash[]
  user               User                @relation(fields: [userId], references: [id])
  TattooHistory      TattooHistory[]
}

//! MODEL POUR LES RDV
model Appointment {
  id                 String              @id @default(cuid())
  title              String
  prestation         PrestationType
  start              DateTime
  end                DateTime
  allDay             Boolean             @default(false)
  status             AppointmentStatus   @default(PENDING)
  isPayed            Boolean             @default(false)
  userId             String              // Salon qui reçoit le RDV
  tatoueurId         String?
  performerUserId    String?
  clientId           String?             // Client existant dans la fiche salon (table Client)
  clientUserId       String?             // NOUVEAU: Client connecté (table User avec role="client")
  skin               String?
  tattooDetailId     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  visio              Boolean             @default(false)
  visioRoom          String?
  followUp7SentAt    DateTime?
  followUp30SentAt   DateTime?
  moodboardId        String?             // Moodboard connecté au rdv par le client

  conversation              Conversation?
  
  // Relations existantes
  client             Client?             @relation(fields: [clientId], references: [id])
  tatoueur           Tatoueur?           @relation(fields: [tatoueurId], references: [id])
  user               User                @relation(fields: [userId], references: [id]) // Salon
  performerUser      User?               @relation("AppointmentPerformer", fields: [performerUserId], references: [id])
  
  // NOUVELLE relation pour client connecté
  clientUser         User?               @relation("ClientUserAppointments", fields: [clientUserId], references: [id])

  // Moodboard connecté au rdv
  moodboard          Moodboard?          @relation(fields: [moodboardId], references: [id], onDelete: SetNull)

  FollowUpRequest    FollowUpRequest?
  FollowUpSubmission FollowUpSubmission?
  tattooDetail       TattooDetail?
  appointmentConsumables AppointmentConsumable[]
  TimeSlot           TimeSlot[]
  salonReview        SalonReview?

  @@index([userId])
  @@index([performerUserId])
  @@index([clientUserId])
  @@index([status])
  @@index([start])
  @@index([followUp7SentAt])
  @@index([followUp30SentAt])
}

//! MODEL POUR LES DÉTAILS D'UN TATOUAGE DANS UN RDV
model TattooDetail {
  id                      String       @id @default(cuid())
  clientId                String?
  appointmentId           String?      @unique
  description             String
  zone                    String?
  size                    String?
  colorStyle              String?
  reference               String?
  sketch                  String?
  piercingZone            PiercingZone?
  piercingServicePriceId  String?      // ID du service de piercing sélectionné
  estimatedPrice          Float?
  price                   Float?
  isPayed                 Boolean      @default(false)
  appointment             Appointment? @relation(fields: [appointmentId], references: [id])
  client                  Client?      @relation(fields: [clientId], references: [id])
  piercingServicePrice    PiercingServicePrice? @relation(fields: [piercingServicePriceId], references: [id])
}

//! MODELS POUR LA GESTION DES PRIX DE PIERCING
model PiercingPrice {
  id               String          @id @default(cuid())
  userId           String
  piercingZone     PiercingZone
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  services         PiercingServicePrice[]
  
  @@unique([userId, piercingZone])
  @@index([userId])
  @@index([piercingZone])
}

model PiercingServicePrice {
  id               String          @id @default(cuid())
  userId           String
  piercingPriceId  String
  piercingZoneOreille  PiercingZoneOreille?
  piercingZoneVisage   PiercingZoneVisage?
  piercingZoneBouche   PiercingZoneBouche?
  piercingZoneCorps    PiercingZoneCorps?
  piercingZoneMicrodermal PiercingZoneMicrodermal?
  price            Float
  description      String?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  piercingPrice    PiercingPrice   @relation(fields: [piercingPriceId], references: [id], onDelete: Cascade)
  tattooDetails    TattooDetail[]  // Relation inverse
  
  @@unique([piercingPriceId, piercingZoneOreille, piercingZoneVisage, piercingZoneBouche, piercingZoneCorps, piercingZoneMicrodermal])
  @@index([userId])
  @@index([piercingPriceId])
}

//! MODEL POUR LES CLIENTS DANS LA FICHE SALON
model Client {
  id                 String               @id @default(cuid())
  userId             String
  firstName          String
  lastName           String
  email              String
  phone              String
  birthDate          DateTime?
  address            String?

  consentSigned      Boolean   @default(false)
  consentSignedAt    DateTime?
  consentFileUrl     String?   // PDF signé stocké
  isMinor            Boolean   @default(false)
  guardianName       String?   // Si mineur
  guardianPhone      String?

  tags                 String[]  // Ex: ["VIP", "habitué", "délicat"]
  marketingConsent     Boolean   @default(false) // RGPD obligatoire

  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  aftercareRecords   Aftercare[]
  appointments       Appointment[]
  user               User                 @relation(fields: [userId], references: [id])
  FollowUpSubmission FollowUpSubmission[]
  medicalHistory     MedicalHistory?
  tattooDetails      TattooDetail[]
  tattooHistory      TattooHistory[]

  linkedUserId       String?
  linkedUser         User?                @relation("LinkedClientProfile", fields: [linkedUserId], references: [id], onDelete: SetNull)

  @@unique([userId, email])
  @@index([linkedUserId])
}

model MedicalHistory {
  id            String  @id @default(cuid())
  clientId      String  @unique
  allergies     String?
  healthIssues  String?
  medications   String?
  pregnancy     Boolean
  previousReactions    String?   // Réactions à des tatouages passés
  tattooHistory String?
  client        Client  @relation(fields: [clientId], references: [id])
}

model TattooHistory {
  id           String    @id @default(cuid())
  clientId     String
  date         DateTime
  description  String?
  inkUsed      String?
  healingTime  String?
  careProducts String?
  photo        String?
  price        Float?
  size         String?
  tatoueurId   String?
  zone         String?
  client       Client    @relation(fields: [clientId], references: [id])
  tatoueur     Tatoueur? @relation(fields: [tatoueurId], references: [id])
}

model Aftercare {
  id                 String   @id @default(cuid())
  clientId           String
  submittedAt        DateTime @default(now())
  photoUrl           String?
  comment            String?
  approved           Boolean  @default(false)
  visibleInPortfolio Boolean  @default(false)
  client             Client   @relation(fields: [clientId], references: [id])
}

//! MODEL POUR LES PLAGES HORAIRES BLOQUÉES (indisponibilités)
model BlockedTimeSlot {
  id         String    @id @default(cuid())
  startDate  DateTime
  endDate    DateTime
  reason     String?
  tatoueurId String?
  userId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tatoueur   Tatoueur? @relation(fields: [tatoueurId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([startDate, endDate])
  @@index([tatoueurId])
  @@index([userId])
}

//! MODEL POUR LES PLAGES HORAIRES DE RDV DISPONIBLES
model TimeSlot {
  id            String       @id @default(cuid())
  date          DateTime
  startTime     DateTime
  endTime       DateTime
  isAvailable   Boolean      @default(true)
  userId        String
  appointmentId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  user          User         @relation(fields: [userId], references: [id])
}

//! MODEL POUR LES IMAGES DE PORTFOLIO
model Portfolio {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  imageUrl    String
  style       String[] @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tatoueurId  String?
  tatoueur    Tatoueur? @relation(fields: [tatoueurId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  favorites   FavoritePortfolio[] @relation("FavoritedPortfolio")
}

//! MODEL POUR LES FAVORIS D'IMAGES DE PORTFOLIO
model FavoritePortfolio {
  id           String    @id @default(cuid())
  clientId     String
  portfolioId  String
  createdAt    DateTime  @default(now())

  client       User      @relation("ClientFavoritePortfolios", fields: [clientId], references: [id], onDelete: Cascade)
  portfolio    Portfolio @relation("FavoritedPortfolio", fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([clientId, portfolioId])
  @@index([clientId])
  @@index([portfolioId])
}

//! MODEL POUR LES PRODUITS EN VENTE DANS LE SALON
model ProductSalon {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  price       Float
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

//! MODEL POUR LES FLASHS DISPONIBLES DU SALON
model Flash {
  id          String   @id @default(cuid())
  userId      String
  tatoueurId  String?
  title       String
  style       String[]
  dimension   String?
  description String?
  imageUrl    String
  price       Float
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tatoueur    Tatoueur? @relation(fields: [tatoueurId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tatoueurId])
  @@index([isAvailable])
}

//! MODEL POUR LES ARTICLES DU SITE PUBLIC (gérés par l'admin)
model Article {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  author      String?
  imageUrls   String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdAt])
}

//! MODEL POUR LA GESTION DU STOCK DE PRODUITS
model StockItem {
  id           String   @id @default(cuid())
  name         String
  category     String?  // "Encre", "Aiguille", "Gant", etc.
  type         String?  // Nouveau champ : type de consommable (ex: "Tatouage", "Piercing", etc.)
  brand        String?
  reference    String?
  pigment      String?
  lotNumber    String?
  expirationDate DateTime?
  notes        String?
  quantity     Int      @default(0)
  unit         String?  // "bouteilles", "boîtes", "pièces", etc.
  minQuantity  Int?     // pour déclencher une alerte
  pricePerUnit Float?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  userId      String
  appointmentConsumables AppointmentConsumable[]

  @@index([userId, lotNumber])
  @@index([reference])
  @@index([expirationDate])
}

//! MODEL POUR LA TRAÇABILITÉ DES CONSOMMABLES UTILISÉS PAR RDV
model AppointmentConsumable {
  id             String    @id @default(cuid())
  appointmentId  String
  userId         String
  stockItemId    String?
  category       String?
  productName    String?
  brand          String?
  reference      String?
  pigment        String?
  lotNumber      String?
  expirationDate DateTime?
  quantity       Float?
  unit           String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  stockItem   StockItem?  @relation(fields: [stockItemId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([userId, lotNumber])
  @@index([lotNumber])
  @@index([reference])
  @@index([expirationDate])
  @@index([category])
}

//! MODEL POUR LES DEMANDES DE SUIVI APRÈS RDV
model FollowUpRequest {
  id            String              @id @default(cuid())
  appointmentId String              @unique
  token         String              @unique
  status        FollowUpStatus      @default(PENDING)
  sentAt        DateTime?
  expiresAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  submissionId  String?             @unique
  userId        String
  appointment   Appointment         @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  submission    FollowUpSubmission? @relation(fields: [submissionId], references: [id])
  user          User                @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

//! MODEL POUR LES SOUMISSIONS DE SUIVI APRÈS RDV
model FollowUpSubmission {
  id              String           @id @default(cuid())
  appointmentId   String           @unique
  clientId        String?
  rating          Int
  review          String?
  photoUrl        String
  isAnswered      Boolean          @default(false)
  response        String?
  isPhotoPublic   Boolean          @default(false)
  createdAt       DateTime         @default(now())
  userId          String
  followUpRequest FollowUpRequest?
  appointment     Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  client          Client?          @relation(fields: [clientId], references: [id])
  user            User             @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
}

// ! MODEL POUR LES DÉTAILS DES PLANS SAAS
model SaasPlanDetails {
  id                 String         @id @default(cuid())
  userId             String         @unique
  currentPlan        SaasPlan       @default(FREE)
  agendaMode         AgendaMode     @default(PAR_TATOUEUR)
  planStatus         SaasPlanStatus @default(ACTIVE)
  startDate          DateTime       @default(now())
  endDate            DateTime?
  trialEndDate       DateTime?
  maxAppointments    Int            @default(30)
  maxClients         Int            @default(50)
  maxTattooeurs      Int            @default(1)
  maxPortfolioImages Int            @default(5)
  hasAdvancedStats   Boolean        @default(false)
  hasEmailReminders  Boolean        @default(false)
  hasCustomBranding  Boolean        @default(false)
  hasApiAccess       Boolean        @default(false)
  monthlyPrice       Float?
  yearlyPrice        Float?
  lastPaymentDate    DateTime?
  nextPaymentDate    DateTime?
  pastDueSince       DateTime?
  paymentMethod      String?
  stripeCustomerId   String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentPlan])
  @@index([planStatus])
  @@index([endDate])
  @@index([pastDueSince])
}

model StripeWebhookEvent {
  id         String   @id @default(cuid())
  eventId    String   @unique
  eventType  String
  createdAt  DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
}

//! MODEL POUR LES DOCUMENTS DE VÉRIFICATION DE SALON
model SalonVerificationDocument {
  id          String                          @id @default(cuid())
  userId      String
  type        SalonVerificationDocumentType
  fileUrl     String                          // URL S3 / Cloudinary / stockage
  status      VerificationStatusDocument              @default(PENDING)
  rejectionReason String?                     // Pourquoi refusé (lisible côté salon)
  uploadedAt  DateTime                        @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?                         // adminId (User admin)

  user        User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])                    // 1 document par type par salon
  @@index([userId])
  @@index([status])
}

//! MODEL POUR LES TOKENS DE VÉRIFICATION ET RÉINITIALISATION DE MOT DE PASSE
model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token], name: "email_token")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token], name: "email_token")
}

//! MODEL CONVERSATION SIMPLIFIÉE (clients connectés uniquement)
model Conversation {
  id                String              @id @default(cuid())
  
  // Participants (SIMPLIFIÉ - clients connectés uniquement)
  salonId           String              // Salon (User avec role="user")
  clientUserId      String              // Client connecté (User avec role="client") - OBLIGATOIRE
  
  // Métadonnées
  appointmentId     String?             @unique  // RDV associé (optionnel)
  subject           String?             // Sujet de la conversation
  status            ConversationStatus  @default(ACTIVE)
  
  // Timestamps
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  lastMessageAt     DateTime            @updatedAt
  
  // Relations
  salon             User                @relation("SalonConversations", fields: [salonId], references: [id], onDelete: Cascade)
  clientUser        User                @relation("ClientUserConversations", fields: [clientUserId], references: [id], onDelete: Cascade)
  appointment       Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  
  messages          Message[]
  notifications     MessageNotification[]
  emailNotifications EmailNotificationQueue[]
  
  // Index pour performance
  @@index([salonId, lastMessageAt])
  @@index([clientUserId, lastMessageAt])
  @@index([appointmentId])
  @@index([status])
  
  // Contrainte unique : 1 conversation par RDV (si appointmentId existe)
  // Permet plusieurs conversations salon-client sans RDV
  @@unique([salonId, clientUserId, appointmentId])
}

//! MODEL MESSAGE (Hard delete)
model Message {
  id                String              @id @default(cuid())
  
  // Contenu
  conversationId    String
  senderId          String              // ID du User (salon ou client connecté)
  content           String              @db.Text // Texte du message (peut être long)
  type              MessageType         @default(TEXT)
  
  // Statut de lecture
  isRead            Boolean             @default(false)
  readAt            DateTime?
  
  // Archivage (auto-cleanup des vieux messages)
  archivedAt        DateTime?           // Si défini, message archivé (soft delete)
  
  // Pièces jointes
  attachments       MessageAttachment[]
  
  // Timestamps
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  conversation      Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender            User                @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  // Index
  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([isRead])
  @@index([archivedAt])
}

//! MODEL ATTACHMENTS (UploadThing URLs)
model MessageAttachment {
  id                String              @id @default(cuid())
  
  messageId         String
  fileName          String
  fileUrl           String              // URL UploadThing
  fileType          String              // mime type (image/png, application/pdf, etc.)
  fileSize          Int                 // en bytes
  uploadThingKey    String?             // Key UploadThing pour gestion/suppression
  
  createdAt         DateTime            @default(now())
  
  message           Message             @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  @@index([messageId])
}

//! MODEL NOTIFICATION COMPTEUR NON LUS
model MessageNotification {
  id                String              @id @default(cuid())
  
  conversationId    String
  userId            String              // Destinataire (salon ou client)
  unreadCount       Int                 @default(0)
  lastUnreadAt      DateTime?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  conversation      Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([conversationId, userId])
  @@index([userId])
  @@index([unreadCount])
}

//! MODEL PREFERENCES NOTIFICATIONS EMAIL
model NotificationPreference {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailNotificationsEnabled Boolean  @default(true)
  emailFrequency            String   @default("IMMEDIATE") // IMMEDIATE, HOURLY, DAILY, NEVER
  mutedConversations        String[] @default([])           // conversationIds

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

//! MODEL QUEUE EMAIL NOTIFICATIONS
model EmailNotificationQueue {
  id               String      @id @default(cuid())
  conversationId   String
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  recipientUserId  String
  messageCount     Int         @default(1)

  status           String      @default("PENDING") // PENDING, SENT, FAILED
  sentAt           DateTime?
  failureReason    String?

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([recipientUserId])
  @@index([status])
  @@index([conversationId])
}

//! MODEL POUR LES DEMANDES D'INTEGRATION D'UN TATOUEUR DANS UNE EQUIPE SALON
model SalonTatoueurTeamRequest {
  id             String            @id @default(cuid())
  salonId        String
  tatoueurUserId String
  message        String?
  status         TeamRequestStatus @default(PENDING)
  respondedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  salon          User              @relation("TeamRequestsSentBySalon", fields: [salonId], references: [id], onDelete: Cascade)
  tatoueurUser   User              @relation("TeamRequestsReceivedByTatoueur", fields: [tatoueurUserId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([tatoueurUserId])
  @@index([status])
  @@unique([salonId, tatoueurUserId, status])
}

enum Role {
  admin
  user         // Ancien rôle (conservé pour compatibilité)
  user_salon   // Propriétaire de salon
  user_tatoueur // Tatoueur indépendant ou rattaché à un salon
  client       // Clients uniquement
  formateur
}

